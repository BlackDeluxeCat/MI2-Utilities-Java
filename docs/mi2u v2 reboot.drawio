        <mxCell id="x4VV83cT4qzIJcIFohZl-18" parent="XGk20LJQXmPGTgXszKcP-75" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;spacing=2;" value="&lt;p style=&quot;text-align: center; margin: 4px 0px 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; text-align: left;&quot;&gt;&lt;b&gt;IslandOverlay&lt;/b&gt;&lt;/span&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: left;&quot;&gt;Manager&lt;/b&gt;&lt;/p&gt;&lt;hr&gt;&lt;div style=&quot;margin-left: 4px;&quot;&gt;+ root: WidgetGroup&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;margin-left: 4px;&quot;&gt;+ islands: Seq&amp;lt;Island&amp;gt;&lt;/div&gt;&lt;div style=&quot;margin-left: 4px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;margin-left: 4px;&quot;&gt;+ saveOverlay(): JsonValue&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;margin-left: 4px;&quot;&gt;+ loadOverlay(JsonValue)&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;margin-left: 4px;&quot;&gt;&lt;hr&gt;&lt;/div&gt;&lt;div style=&quot;margin-left: 4px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;// 编辑模式单例对象&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;margin-left: 4px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;margin-left: 4px;&quot;&gt;// 小组件点菜单&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ widgetShop: WidgetShop&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;// 一级菜单，自建。包含路径面包屑、各二级设置页入口、删除图表入口&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;// islandlayout设置、islandcontent设置、capabilities设置、layouttree设置&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ islandConfiguresPanel: Table&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;&amp;nbsp;// 二级设置页，同时只显示一个二级页，委托给island处理&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ islandConfigureTable: Table&lt;/p&gt;&lt;hr&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="440" width="240" x="320" y="40" as="geometry" />
        </mxCell>
        <mxCell id="x4VV83cT4qzIJcIFohZl-64" parent="XGk20LJQXmPGTgXszKcP-75" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;" value="&lt;p style=&quot;text-align: center; margin: 4px 0px 0px;&quot;&gt;&lt;b style=&quot;background-color: transparent; text-align: left; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;WidgetShop&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot; style=&quot;border-style:solid;&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;// TODO&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;小组件列表和添加器&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;添加单个Widget或者预制的Island&lt;/p&gt;" vertex="1">
