        <mxCell id="XGk20LJQXmPGTgXszKcP-44" parent="XGk20LJQXmPGTgXszKcP-64" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;Island&lt;/b&gt;&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent; text-align: left;&quot;&gt;extends&amp;nbsp;&lt;/span&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;/b&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;arc.scene.ui.layout.Table&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;&amp;nbsp;&lt;/b&gt;implements&amp;nbsp;&lt;b&gt;arc.util.serialization.Json&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;.JsonSerializable&lt;/b&gt;&lt;/span&gt;&lt;b&gt;&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot; style=&quot;border-style:solid;&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ name: String&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;+ showCondition(Boolp)&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;+ content: IslandContent?&lt;/p&gt;&lt;hr&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;+ capabilities(): Seq&amp;lt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ElementCapability&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/p&gt;&lt;hr&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;+ layout: IslandLayout&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;+ parentIsland:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Island? // null为root&lt;/span&gt;&lt;/p&gt;&lt;hr&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;+ rebuild()&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;// 除了capabilities还没拆分出去，都是委托处理&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;+ buildLayoutSettingsTable(Table)&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;+ buildCapabilitiesSettingsTable(Table)&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px; padding-left: 0px;&quot;&gt;+ buildContentSettingsTable(Table)&lt;/p&gt;" vertex="1">
